//if end<start, no overlap
// else, overlapped
// 1st one, always push like ans is empty aythe, then adhi merged aythe, change the end in else part

vector<vector<int>> mergeHighDefinitionIntervals(vector<vector<int>> intervals) {
   vector<vector<int>> ans;

   sort(intervals.begin(), intervals.end()); //sort based on key,if they same,based on value
   
   for(int i=0;i<intervals.size();i++){
    if(ans.empty() || ans.back()[1]<intervals[i][0]){
        ans.push_back(intervals[i]);
    }else{
        ans.back()[1]=max(ans.back()[1], intervals[i][1]);
    }
   }
   return ans;

}
