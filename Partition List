// create 2 lists
// then traverse , and keeep small in small list
// keep large value in large list
// combine both

class Solution {
public:
    ListNode* partition(ListNode* head, int x) {
        ListNode* small = new ListNode(0);
        ListNode* large = new ListNode(0);
        ListNode* s = small;
        ListNode* l = large;

        while(head!=NULL){
            if(head->val < x){
                s->next=head;
                s=s->next;
            }else{
                l->next=head;
                l=l->next;
            }
            head=head->next;
        }
        l->next=NULL;
        s->next=large->next;

        return small->next;
    }
};
