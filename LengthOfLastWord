class Solution {
public:
    int lengthOfLastWord(string s) {
        int n=s.length();
        int length=0;
        int i=n-1;

        while(i>=0 && s[i]==' '){
            i--;    //skippimg trailing spaces
        }

        while(i>=0 && s[i]!=' '){
            length++;  //space to another space, add length
            i--;
        }
        return length;

    }
};
