#include<bits/stdc++.h>
using namespace std;

int main(){
    int n;
    cin>>n;  //100
    
    vector<int>arr;
    
    for(int i=1;i*i<=n;i++){ //loop goes until 1 to 10
        if(n%i==0){
            arr.push_back(i);  // 10 went
            
            int other= n/i; // 100/10 =10
            if(other!=i && other!=n){ //10=10 , so dont push again..also for i=1, 100/1=100, dont push
                arr.push_back(other);
            }
        }
    }
    //without sort: 1 2 50 4 25 5 20 10
    sort(arr.begin(),arr.end());
    
    for(int i:arr){
        cout<<i<<" ";
    }
    cout<<endl;
    cout<<arr.back();
    return 0;
}

