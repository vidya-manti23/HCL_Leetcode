// rightmost of left subtree -> curr->right
// curr-> right = curr->left


class Solution {
public:
    void flatten(TreeNode* root) {
        if(root==nullptr) return;
        TreeNode* curr= root;
        TreeNode* prev= NULL;
        while(curr!=NULL){
            if(curr->left!=NULL){
            prev=curr->left;
            while(prev->right){
               prev=prev->right;  //go right most in left subtree
            }
            prev->right=curr->right; //thread
            curr->right=curr->left; //curr->left vundadhu..
            curr->left=NULL;
            }
         curr=curr->right;
        }       
    }
};
